# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,https://app.fieldeaze.com

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://fieldeaze:secret@localhost:5432/fieldeaze_db?schema=public"
POSTGRES_DB=fieldeaze_db
POSTGRES_USER=fieldeaze
POSTGRES_PASSWORD=secret

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-use-different-string
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary (file uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Firebase FCM ─────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json

# ─── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@fieldeaze.com
